PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS — domain frontend Vercel kamu
FRONTEND_URL=http://localhost:3000

# API Key sederhana untuk proteksi endpoint (ganti dengan random string panjang)
API_KEY=ganti-dengan-string-acak-panjang-min-32-karakter

# Delay antar pesan (ms) — untuk hindari banned WhatsApp
MIN_DELAY_MS=5000
MAX_DELAY_MS=15000

# Limit pesan per session per hari
DAILY_LIMIT_PER_SESSION=300

# Retention: campaign completed/cancelled lebih dari N hari otomatis dihapus (default 30)
CAMPAIGN_RETENTION_DAYS=30
